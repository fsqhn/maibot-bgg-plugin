{
  "manifest_version": 2,
  "name": "桌游搜索插件 (bgg_search_plugin)",
  "version": "0.0.7",
  "description": "利用集石、DDGS 和 LLM 查询桌游英文名，然后从 BGG 网站获取游戏的相关基本信息",
  "author": {
    "name": "山上的小丘",
    "url": "https://github.com/fsqhn"
  },
  "license": "GPL-v3.0-or-later",

  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },

  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },

  "capabilities": [
    "llm.generate",
	"llm.get_available_models",
    "message.get_by_time_in_chat",
    "config.get",
    "send.text",
    "send.image",
    "send.forward"
  ],

  "i18n": {
    "default_locale": "zh-CN"
  },

  "urls": {
    "repository": "https://github.com/fsqhn/maibot-bgg-plugin" ,
    "homepage": "https://github.com/fsqhn/maibot-bgg-plugin"
  },

  "id": "fsqhn.bgg_search_plugin"
}